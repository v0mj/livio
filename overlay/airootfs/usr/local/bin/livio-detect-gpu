#!/usr/bin/env bash
set -euo pipefail

gpu_text="$(lspci -nn 2>/dev/null | grep -Ei 'vga|3d|display' || true)"
virt_name="$(systemd-detect-virt --vm 2>/dev/null || true)"

recommendation="gpu-open"
detected="unknown"
message="Open-source Mesa graphics are recommended for this system."

if [[ -n "$virt_name" ]]; then
    recommendation="gpu-open"
    detected="virtual-machine"
    message="Virtual machine detected (${virt_name}); use the AMD / Intel (Mesa) option unless you are passing through a physical GPU."
elif grep -Eiq 'nvidia' <<<"$gpu_text"; then
    if grep -Eiq 'intel|amd|advanced micro devices|ati' <<<"$gpu_text"; then
        recommendation="gpu-hybrid"
        detected="nvidia-hybrid"
        message="NVIDIA plus another GPU detected; the Hybrid / Multi-vendor option is the safest installer choice."
    else
        recommendation="gpu-nvidia"
        detected="nvidia"
        message="NVIDIA graphics detected; choose NVIDIA Proprietary if this is the GPU you will use."
    fi
elif grep -Eiq 'amd|advanced micro devices|ati' <<<"$gpu_text"; then
    recommendation="gpu-open"
    detected="amd"
    message="AMD graphics detected; choose AMD / Intel (Mesa) for the best supported open-source stack."
elif grep -Eiq 'intel' <<<"$gpu_text"; then
    recommendation="gpu-open"
    detected="intel"
    message="Intel graphics detected; choose AMD / Intel (Mesa) for the standard open-source stack."
fi

case "${1:-}" in
    --id)
        printf '%s\n' "$recommendation"
        ;;
    --message)
        printf '%s\n' "$message"
        ;;
    --detected)
        printf '%s\n' "$detected"
        ;;
    --summary)
        printf 'detected=%s\nrecommended=%s\n%s\n' "$detected" "$recommendation" "$message"
        ;;
    --notify)
        if command -v notify-send >/dev/null 2>&1 && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
            notify-send "Livio OS graphics" "$message" || true
        elif command -v kdialog >/dev/null 2>&1 && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
            kdialog --title "Livio OS graphics" --passivepopup "$message" 8 || true
        else
            printf '%s\n' "$message"
        fi
        ;;
    *)
        printf 'detected=%s\nrecommended=%s\n%s\n' "$detected" "$recommendation" "$message"
        ;;
esac
