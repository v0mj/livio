#!/usr/bin/env bash
set -euo pipefail

retry() {
    local attempts="$1"
    local delay="$2"
    shift 2

    local attempt
    for (( attempt = 1; attempt <= attempts; attempt++ )); do
        if "$@"; then
            return 0
        fi

        if (( attempt == attempts )); then
            return 1
        fi

        echo "Attempt $attempt failed, retrying in ${delay}s: $*" >&2
        sleep "$delay"
    done
}

if ! flatpak remotes --columns=name | grep -qx flathub; then
    retry 3 5 sudo flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
fi

retry 3 10 sudo flatpak install -y --noninteractive flathub com.heroicgameslauncher.hgl
