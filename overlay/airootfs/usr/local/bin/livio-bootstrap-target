#!/usr/bin/env bash
set -euo pipefail

shopt -s nullglob

target_root="${1:?target root is required}"

retry() {
    local attempts="$1"
    local delay="$2"
    shift 2

    local attempt
    for (( attempt = 1; attempt <= attempts; attempt++ )); do
        if "$@"; then
            return 0
        fi

        if (( attempt == attempts )); then
            return 1
        fi

        echo "Attempt $attempt failed, retrying in ${delay}s: $*" >&2
        sleep "$delay"
    done
}

refresh_live_mirrors() {
    if command -v reflector >/dev/null 2>&1; then
        reflector --latest 20 --protocol https --sort rate --save /etc/pacman.d/mirrorlist || \
            echo "Mirror refresh failed; keeping the existing mirrorlist." >&2
    fi

    retry 3 5 pacman -Sy --noconfirm archlinux-keyring || \
        retry 3 5 pacman -Sy --noconfirm
}

install_livio_release() {
    local release_pkgs=(/usr/share/livio/packages/livio-release-*.pkg.tar.zst)

    if (( ${#release_pkgs[@]} == 0 )); then
        echo "Livio release package cache missing; copying identity files directly." >&2
        install -Dm644 /usr/lib/os-release "$target_root/usr/lib/os-release"
        install -Dm644 /etc/lsb-release "$target_root/etc/lsb-release"
        return 0
    fi

    install -Dm644 "${release_pkgs[0]}" "$target_root/tmp/livio-release.pkg.tar.zst"
    retry 3 5 arch-chroot "$target_root" pacman -U --noconfirm /tmp/livio-release.pkg.tar.zst
    rm -f "$target_root/tmp/livio-release.pkg.tar.zst"
}

configure_livio_local_repo() {
    local repo_src="/usr/share/livio/packages"
    local repo_dst="$target_root/usr/share/livio/packages"

    if ! compgen -G "$repo_src/*.pkg.tar.zst" >/dev/null; then
        return 0
    fi

    mkdir -p "$repo_dst"
    cp -a "$repo_src/." "$repo_dst/"

    if [[ ! -f "$repo_dst/livio-local.db" && ! -f "$repo_dst/livio-local.db.tar.zst" ]]; then
        echo "Livio local package cache exists but has no repo database; selected local packages may not install." >&2
        return 0
    fi

    if ! grep -q '^\[livio-local\]' "$target_root/etc/pacman.conf"; then
        cat >> "$target_root/etc/pacman.conf" <<'PACMAN'

[livio-local]
SigLevel = Optional TrustAll
Server = file:///usr/share/livio/packages
PACMAN
    fi
}

base_packages=(
    base
    btrfs-progs
    cryptsetup
    device-mapper
    dosfstools
    e2fsprogs
    efibootmgr
    exfatprogs
    f2fs-tools
    grub
    inetutils
    less
    linux-firmware
    linux-lts
    linux-lts-headers
    lsb-release
    lvm2
    man-db
    man-pages
    mdadm
    mkinitcpio
    nano
    networkmanager
    os-prober
    sudo
    vim
    which
    xfsprogs
)

refresh_live_mirrors

retry 3 15 pacstrap -K -C /etc/pacman.conf "$target_root" "${base_packages[@]}"

install -Dm644 /etc/pacman.conf "$target_root/etc/pacman.conf"
configure_livio_local_repo
install -Dm755 /usr/local/bin/livio-check-system "$target_root/usr/local/bin/livio-check-system"
install -Dm755 /usr/local/bin/livio-install-heroic "$target_root/usr/local/bin/livio-install-heroic"

install_livio_release
